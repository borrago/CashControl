{
  "DeploymentTopology": {
    "PublicAppOrigin": "https://localhost:5173",
    "PublicApiOrigin": "https://localhost:5001",
    "RequireHttps": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173"
    ],
    "AllowCredentials": true
  },
  "SessionCookie": {
    "Name": "__Host-cashcontrol-session",
    "Domain": null,
    "SameSite": "Lax",
    "SecurePolicy": "SameAsRequest",
    "SlidingExpiration": true,
    "ExpireHours": 8
  },
  "Antiforgery": {
    "HeaderName": "X-CSRF-TOKEN",
    "CookieName": "__Host-cashcontrol-csrf",
    "CookieDomain": null,
    "SameSite": "Lax",
    "SecurePolicy": "SameAsRequest"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
